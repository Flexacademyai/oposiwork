# ──────────────────────────────────────────────────────────────
# Oposiwork — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees .env — está en .gitignore
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Obtener en: Dashboard → Settings → API
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJ...tu_anon_key
# SUPABASE_SERVICE_KEY solo para scripts de backend, NUNCA en Flutter
SUPABASE_SERVICE_KEY=eyJ...tu_service_key

# ── RevenueCat ────────────────────────────────────────────────
# Obtener en: app.revenuecat.com → Project → API Keys
REVENUECAT_API_KEY_IOS=appl_tu_api_key
REVENUECAT_API_KEY_ANDROID=goog_tu_api_key
# Secret key solo para Edge Functions (verify-subscription)
REVENUECAT_API_KEY_SECRET=tu_secret_key

# ── Anthropic (solo pipeline de contenido Python) ─────────────
ANTHROPIC_API_KEY=sk-ant-tu_api_key

# ── OpenAI (Edge Functions: chat-rag, crear-sesion-voz) ───────
OPENAI_API_KEY=sk-tu_openai_key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=alloy

# ── Edge Functions — configuración ────────────────────────────
# Tiempo de voz mensual en segundos (plan mensual)
VOICE_MONTHLY_LIMIT_SECONDS=1800
# Salt para hash de IPs (rate limiting)
IP_HASH_SALT=cadena-aleatoria-segura-32-caracteres
# Secret para el cron job de monitor-boe
CRON_SECRET=otro-secreto-largo-y-aleatorio

# ── Firebase (archivos, no variables) ─────────────────────────
# Descarga manualmente desde Firebase Console y coloca en:
#   android/app/google-services.json
#   ios/Runner/GoogleService-Info.plist
# Estos archivos están en .gitignore

# ── Stripe (solo web) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_tu_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_live_tu_stripe_key
STRIPE_PRICE_MONTHLY=price_tu_plan_mensual
STRIPE_PRICE_ANNUAL=price_tu_plan_anual
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret
APP_BASE_URL=https://www.oposiwork.com

# MVP: mantener pagos desactivados hasta completar la validacion final de Stripe/App Store/Google Play.
# Cambiar a true solo cuando el checkout web, webhooks y compras in-app esten verificados.
PAGOS_HABILITADOS=false
